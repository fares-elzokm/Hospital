  <property name="styleSheet">
   <string notr="true">/* --- Thor Theme QSS --- */

/* Main Window &amp; Central Widget */
QMainWindow, QWidget#centralwidget, QDialog#Patient {
    background-color: #0D1117;
}

/* --- Frame --- */
QWidget#frame
{
    background-color: transparent;
}
/* --- Sidebar --- */
QWidget#sidebar {
    background-color: #161B22;
    border-radius: 10px;
}
QWidget#sidebar QPushButton {
    background-color: transparent;
    border: none;
    color: #E6EDF3;
    padding: 10px;
    padding-left: 15px;
    border-radius: 5px;
    text-align: left;
}
QWidget#sidebar QPushButton:hover {
    background-color: #21262D;
}
QWidget#sidebar QPushButton:pressed,
QWidget#sidebar QPushButton:checked {
    background-color: #00F6FF;
    color: #0D1117;
}

/* --- Topbar --- */
QFrame#topbar {
    background-color: #161B22;
    border-radius: 8px;
}
QFrame#topbar QPushButton {
    background-color: transparent;
    border: none;
    border-radius: 4px;
    padding: 5px;
    text-align: center;
}
QFrame#topbar QPushButton:hover {
    background-color: #21262D;
}
QFrame#topbar QPushButton#closeButton:hover {
    background-color: #E81123;
}

/*--- bottomBarFrame --*/
QFrame#bottomBarFrame {
    background-color: #161B22;
    border-radius: 8px;
}
/* --- Main Content Area --- */
QFrame#content, QStackedWidget &gt; QWidget {
    background-color: #0D1117;
    border: none;
}

/* General Page Titles */
QLabel#pageTitle {
    color: #E6EDF3;
    font-size: 14pt;
    font-weight: bold;
}

/* --- Form Specific --- */
QFrame#formFrame {
    background-color: #161B22;
    border-radius: 8px;
}

#formFrame QLabel {
 color: #E6EDF3;
 font-size: 11pt;
 padding-bottom: 5px;
}

/* --- Table View --- */
QTableView {
    background-color: #161B22;
    border: 1px solid #21262D;
    border-radius: 8px;
    gridline-color: #21262D;
    color: #E6EDF3;
}
QTableView::item {
    padding: 5px;
    border-bottom: 1px solid #21262D;
}
QTableView::item:selected {
    background-color: #00F6FF;
    color: #0D1117;
}
QHeaderView::section {
    background-color: #0D1117;
    color: #E6EDF3;
    padding: 5px;
    border: 1px solid #21262D;
    font-weight: bold;
}

/* --- Line Edit &amp; ComboBox --- */
QLineEdit, QComboBox {
    background-color: #0D1117;
    border: 1px solid #21262D;
    border-radius: 5px;
    padding: 8px 10px;
    color: #E6EDF3;
    font-size: 10pt;
}
QLineEdit:focus, QComboBox:focus {
    border-color: #00F6FF;
}
QComboBox::drop-down {
    border: none;
}
QComboBox::down-arrow {
    image: url(:/img/chevron-down.svg); /* Ensure you have this icon */
    width: 12px;
    height: 12px;
}
QComboBox QAbstractItemView {
    background-color: #161B22;
    border: 1px solid #21262D;
    color: #E6EDF3;
    selection-background-color: #00F6FF;
    selection-color: #0D1117;
}

/* --- Main Action Button --- */
QPushButton#saveButton {
    background-color: #00F6FF;
    color: #0D1117;
    border-radius: 5px;
    padding: 8px 16px;
    font-weight: bold;
    font-size: 11pt;
}
QPushButton#saveButton:hover {
    background-color: #33fdff;
}
</string>
