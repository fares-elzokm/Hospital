  <widget class="QWidget" name="centralwidget">
   <property name="styleSheet">
    <string notr="true">/* --- Thor Theme QSS --- */

/* Main Window &amp; Central Widget */
QMainWindow, QWidget#centralwidget {
    background-color: #0D1117;
}

/* --- Frame --- */
QWidget#frame
{
	background-color: transparent;
}
/* --- Sidebar --- */
QWidget#sidebar {
    background-color: #161B22;
	border-radius: 10px;
}
QWidget#sidebar QPushButton {
    background-color: transparent;
    border: none;
    color: #E6EDF3;
    padding: 10px;
    padding-left: 15px;
    border-radius: 5px;
    text-align: left;
}
QWidget#sidebar QPushButton:hover {
    background-color: #21262D;
}
QWidget#sidebar QPushButton:pressed,
QWidget#sidebar QPushButton:checked {
    background-color: #00F6FF;
    color: #0D1117;
}

/* --- Topbar --- */
QFrame#topbar {
    background-color: #161B22;
}
QFrame#topbar QPushButton {
    background-color: transparent;
    border: none;
    border-radius: 4px;
    padding: 5px;
    text-align: center;
}
QFrame#topbar QPushButton:hover {
    background-color: #21262D;
}
QFrame#topbar QPushButton#close:hover {
    background-color: #E81123;
}

/* --- Main Content Area --- */
QFrame#content, QStackedWidget &gt; QWidget {
    background-color: #0D1117;
    border: none;
}

/* General Page Titles */
QLabel#pageTitle, QLabel#departmentTitle, QLabel#docterTitle, QLabel#pageTitle_2{
    color: #E6EDF3;
    font-size: 18pt;
    font-weight: bold;
}

/* --- Dashboard Specific Styles --- */
#homePage .QFrame {
    background-color: #161B22;
    border-radius: 12px;
}
#homePage QLabel {
    color: #E6EDF3;
    font-size: 11pt;
}
#homePage #mainChartTitle, #homePage #barChartTitle {
    font-size: 14pt;
    font-weight: bold;
    padding: 5px;
}
#homePage QProgressBar {
    border: 1px solid #21262D;
    border-radius: 5px;
    text-align: center;
    color: #E6EDF3;
    background-color: #0D1117;
}
#homePage QProgressBar::chunk {
    background-color: #00F6FF;
    border-radius: 4px;
}
#homePage #op1Button, #homePage #op2Button {
    background-color: #00F6FF;
    color: #0D1117;
    border-radius: 5px;
    padding: 5px 10px;
    font-weight: bold;
}

/* --- Patients &amp; Appointments Page Styles --- */
#patientsPage QPushButton, #appointmentsPage QPushButton {
    background-color: #00F6FF;
    color: #0D1117;
    border-radius: 5px;
    padding: 8px 12px;
    font-weight: bold;
}
#patientsPage QPushButton:hover, #appointmentsPage QPushButton:hover {
    background-color: #33fdff;
}

/* --- Department --- */
#department QPushButton, #addDepartment QPushButton {
    background-color: #00F6FF;
    color: #0D1117;
    border-radius: 5px;
    padding: 8px 12px;
    font-weight: bold;
}
#department QPushButton:hover, #addDepartment QPushButton:hover {
    background-color: #33fdff;
}

#doctor QPushButton, #docterPage QPushButton {
    background-color: #00F6FF;
    color: #0D1117;
    border-radius: 5px;
    padding: 8px 12px;
    font-weight: bold;
}
#doctor QPushButton:hover, #docterPage QPushButton:hover {
    background-color: #33fdff;
}

/* --- Table View --- */
QTableView {
    background-color: #161B22;
    border: 1px solid #21262D;
    border-radius: 8px;
    gridline-color: #21262D;
    color: #E6EDF3;
}
QTableView::item {
    padding: 5px;
    border-bottom: 1px solid #21262D;
}
QTableView::item:selected {
    background-color: #00F6FF;
    color: #0D1117;
}
QHeaderView::section {
    background-color: #0D1117;
    color: #E6EDF3;
    padding: 5px;
    border: 1px solid #21262D;
    font-weight: bold;
}

/* --- Line Edit (Search Bar) --- */
QLineEdit {
    background-color: #0D1117;
    border: 1px solid #21262D;
    border-radius: 5px;
    padding: 8px 10px;
    color: #E6EDF3;
}
QLineEdit:focus {
    border-color: #00F6FF;
}

/* --- Calendar Widget --- */
QCalendarWidget QToolButton {
    color: #E6EDF3;
    background-color: transparent;
    border: none;
    font-size: 14px;
    font-weight: bold;
}
QCalendarWidget QToolButton:hover {
    background-color: #21262D;
}
QCalendarWidget QMenu {
    background-color: #161B22;
}
QCalendarWidget QSpinBox {
    color: #E6EDF3;
}
QCalendarWidget QWidget#qt_calendar_navigationbar {
    background-color: #161B22;
    border: 1px solid #21262D;
    border-bottom: none;
    border-radius: 8px 8px 0 0;
}
QCalendarWidget QAbstractItemView {
    background-color: #0D1117;
    color: #E6EDF3;
    selection-background-color: #00F6FF;
    selection-color: #0D1117;
    border: 1px solid #21262D;
    border-top: none;
    border-radius: 0 0 8px 8px;
}
QCalendarWidget QAbstractItemView:disabled {
    color: #4E535A;
}
</string>
